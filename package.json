{
  "name": "tflygcs",
  "version": "1.0.0",
  "description": "TihanFly Ground Control Station",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "author": "Pavan",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.tihan.fly",
    "productName": "TihanFly",
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "${productName}-${version}.exe"
    },
    "extraResources": [
      {
        "from": "TihanFlyCC-main/build/Release",
        "to": "backend",
        "filter": ["**/*"]
      },
      "video_server.exe"
    ]
  }
}

