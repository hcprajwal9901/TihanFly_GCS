# ============================================================
#  TflyGCS — Ground Control Station
#  .gitignore covering:
#    • Node.js / Electron frontend
#    • C++ / CMake backend (TihanFlyCC-main)
#    • VS Code workspace settings
#    • Windows & macOS system files
# ============================================================


# ─── Node.js / npm ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnpm-debug.log*

# Lock files (keep package-lock.json if you want reproducible installs)
# package-lock.json
# yarn.lock


# ─── Electron ───────────────────────────────────────────────
# Electron-builder output
dist/
out/
release/
build-electron/
build/
build_dist/

# Electron packager cache
.cache/
.webpack/

# electron-rebuild
.node_gyp/


# ─── C++ / CMake (TihanFlyCC-main) ──────────────────────────
# CMake build directories
TihanFlyCC-main/build/
TihanFlyCC-main/output/
TihanFlyCC-main/cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
CTestTestfile.cmake
_deps/

# Compiled binaries & object files
*.exe
*.out
*.app
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.pdb
*.ilk
*.exp

# vcpkg / dependency caches
vcpkg_installed/
.vcpkg/

# MinGW / MSVC generated
*.res
*.rc
*.manifest


# ─── Logs & Runtime Data ────────────────────────────────────
logs/
*.log
*.log.*
pids/
*.pid
*.seed
*.pid.lock

# MAVLink / flight logs
*.tlog
*.bin
*.ulg
*.param
*.waypoints


# ─── VS Code ────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/c_cpp_properties.json
*.code-workspace


# ─── Environment & Secrets ──────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12


# ─── OS-generated files ─────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.nfs*


# ─── Coverage & Testing ─────────────────────────────────────
coverage/
*.lcov
.nyc_output/


# ─── Misc ───────────────────────────────────────────────────
*.bak
*.swp
*.tmp
*.orig
*.rej
.sass-cache/
